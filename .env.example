# Basic runner settings
RUNNER_URL=https://github.com/your-org/your-repo
RUNNER_LABELS=docker,linux,x64
RUNNER_GROUP=Default
RUNNER_WORKDIR=_work

# Optional: set a fixed runner name. Leave empty to use the container hostname.
RUNNER_NAME=

# Re-register on every container start by default to avoid stale runner state and one-time token reuse.
FORCE_RECONFIGURE=true

# Legacy/manual mode: short-lived GitHub runner registration token
RUNNER_TOKEN=

# Dynamic bootstrap mode: long-lived GitHub credential used to request a short-lived registration token
GITHUB_TOKEN=

# Optional override for GitHub Enterprise Server API base URL
# GITHUB_API_URL=https://github.example.com/api/v3
